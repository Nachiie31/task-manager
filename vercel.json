{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/landing.css", "dest": "/public/landing.css" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/app.js", "dest": "/public/app.js" },
    { "src": "/auth.js", "dest": "/public/auth.js" },
    { "src": "/dashboard.js", "dest": "/public/dashboard.js" },
    { "src": "/login.html", "dest": "/public/login.html" },
    { "src": "/signup.html", "dest": "/public/signup.html" },
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    { "src": "/pricing.html", "dest": "/public/pricing.html" },
    { "src": "/success.html", "dest": "/public/success.html" },
    { "src": "/cancel.html", "dest": "/public/cancel.html" },
    { "src": "/", "dest": "/public/index.html" }
  ]
}