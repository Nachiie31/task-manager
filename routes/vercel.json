{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "public/index.html"
    },
    {
      "src": "/success.html",
      "dest": "public/success.html"
    },
    {
      "src": "/cancel.html",
      "dest": "public/cancel.html"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}